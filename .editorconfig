# EditorConfig — consistent formatting across the repo (https://editorconfig.org)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{tf,tfvars,hcl}]
indent_size = 2

[*.{py}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false  # markdown hard line-breaks use trailing spaces

[Makefile]
indent_style = tab
